# Fake example configuration. Copy to .env and edit for your local machine.
# OpenCode databases may contain private prompts, messages, project paths, and token metadata.

OPENCODE_MAIN_DB=~/.local/share/opencode/opencode.db
OPENCODE_ARCHIVE_DB=~/.local/share/opencode/opencode_archive.db
OPENCODE_OLD_ARCHIVE_DB=~/.local/share/opencode/archive/old_sessions.db

# Optional: path used by CLI workflows that initialize a new archive DB from a schema-only template.
OPENCODE_EMPTY_TEMPLATE_DB=tests/fixtures/empty_opencode.db
